{
  "name": "checkov-coverage-comment",
  "version": "1.2.2",
  "description": "GitHub Action to post Checkov scan results as a PR comment grouped by severity",
  "main": "dist/index.js",
  "author": "bavakesavan",
  "repository": {
    "type": "git",
    "url": "https://github.com/bavakesavan/checkov-coverage-comment"
  },
  "scripts": {
    "build": "tsc --noEmit && esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/index.js --minify --sourcemap",
    "test": "vitest run",
    "lint": "eslint src __tests__",
    "lint:fix": "eslint src __tests__ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release": "node scripts/release.mjs",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=24"
  },
  "license": "MIT",
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "__tests__/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
