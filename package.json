{
  "name": "checkov-coverage-comment",
  "version": "1.1.0",
  "description": "GitHub Action to post Checkov scan results as a PR comment grouped by severity",
  "main": "dist/index.js",
  "author": "bavakesavan",
  "repository": {
    "type": "git",
    "url": "https://github.com/bavakesavan/checkov-coverage-comment"
  },
  "scripts": {
    "build": "tsc && ncc build src/index.ts -o dist --minify --source-map --license licenses.txt",
    "test": "vitest run",
    "lint": "eslint src __tests__",
    "lint:fix": "eslint src __tests__ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release": "node scripts/release.mjs",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=24"
  },
  "license": "MIT",
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "__tests__/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^9.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^1.6.0"
  }
}
